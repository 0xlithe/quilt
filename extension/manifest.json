{
  "manifest_version": 3,
  "name": "quilt",
  "short_name": "quilt",
  "version": "0.3.0",
  "description": "A focused automation workspace for X with human-tuned timing, task controls, and session safety.",
  "permissions": ["storage", "activeTab", "tabs", "scripting", "sidePanel"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*"],
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "options_ui": {
    "page": "ui/options.html",
    "open_in_tab": false
  },
  "action": {
    "default_title": "quilt",
    "default_popup": "ui/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "ui/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": [
        "messaging/messaging.js",
        "storage/storage.js",
        "content/debug.js",
        "safety/delay.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
